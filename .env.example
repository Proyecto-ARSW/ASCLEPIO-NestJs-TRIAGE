# =============================================
# DATABASE
# =============================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/asclepio?schema=triage"

# =============================================
# REDIS
# =============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# =============================================
# RABBITMQ
# =============================================
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE_TRIAGE=triage_events
RABBITMQ_EXCHANGE=asclepio_exchange

# =============================================
# MICROSERVICIOS
# =============================================
# URL del microservicio de IA preliminar (Ollama)
OLLAMA_PRELIM_URL=http://localhost:3002

# URL del microservicio de IA clasificación (Random Forest)
TRIAGE_CLASSIFIER_URL=http://localhost:3003

# URL del microservicio Core
CORE_API_URL=http://localhost:3000

# =============================================
# SERVER
# =============================================
PORT=3001
NODE_ENV=development

# =============================================
# JWT (compartido con Core)
# =============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=1d

# =============================================
# CORS
# =============================================
CORS_ORIGIN=http://localhost:5173

# =============================================
# MONITORING
# =============================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=4001

# =============================================
# LOGGING
# =============================================
LOG_LEVEL=debug