# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/asclepio?schema=triage"

# ============================================
# REDIS
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# ============================================
# RABBITMQ
# ============================================
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=asclepio_exchange
RABBITMQ_QUEUE_TRIAGE=triage_events

# ============================================
# MICROSERVICIOS EXTERNOS
# ============================================
# MS 3: Ollama - Evaluación preliminar
OLLAMA_SERVICE_URL=http://localhost:3002

# MS 4: Random Forest - Clasificador de triage
CLASSIFIER_SERVICE_URL=http://localhost:3003

# MS 1: Core - API principal de ASCLEPIO
CORE_API_URL=http://localhost:3000

# Clave compartida con ISISvoice (ISISvoice debe enviar esto en x-api-key)
ISISVOICE_WEBHOOK_SECRET=

# Clave para autenticarse ante ASCLEPIO-NestJS-M1 (debe coincidir con TRIAGE_API_KEY de M1)
CORE_API_KEY=

# Clave para autenticarse ante MikeTriage (MikePY debe validar este valor)
CLASSIFIER_API_KEY=

# ============================================
# API CONFIGURATION
# ============================================
PORT=3001
API_PREFIX=api/triage
USE_API_GATEWAY=false

# ============================================
# FRONTEND
# ============================================
FRONTEND_URL=http://localhost:5173

# ============================================
# JWT SECRETS (CAMBIAR EN PRODUCCIÓN)
# ============================================
JWT_SECRET=dev-secret-key-DO-NOT-USE-IN-PRODUCTION
JWT_REFRESH_SECRET=dev-refresh-secret-key-DO-NOT-USE-IN-PRODUCTION
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ============================================
# FEATURES FLAGS (opcional)
# ============================================
ENABLE_SWAGGER=true
ENABLE_METRICS=true